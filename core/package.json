{
  "name": "@argonguard/core",
  "version": "0.1.0-dev",
  "description": "ArgonGuard 規格層（平台無關）：PHC parser/encoder、OWASP frontier 政策、needsRehash、base64、constant-time，以及 Argon2Provider / CryptoPrimitives 注入邊界。密碼學引擎與 CSPRNG 由平台套件（node/edge）注入。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Megapower-Asia-LLC/ArgonGuard.git",
    "directory": "core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@types/node": "^22.20.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
