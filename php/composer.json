{
    "name": "argonguard/passwords",
    "description": "OWASP-compliant Argon2id password hashing component. Implements ArgonGuard Spec (PHC string format, OWASP frontier verification policy).",
    "license": "MIT",
    "type": "library",
    "keywords": ["argon2id", "argon2", "password-hashing", "owasp", "phc", "security", "password"],
    "homepage": "https://github.com/Megapower-Asia-LLC/ArgonGuard",
    "authors": [
        {
            "name": "Megapower Asia LLC",
            "homepage": "https://megapower.asia"
        }
    ],
    "support": {
        "issues": "https://github.com/Megapower-Asia-LLC/ArgonGuard/issues",
        "source": "https://github.com/Megapower-Asia-LLC/argonguard-php"
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-sodium": "Production verify fallback when PHP is built without argon2id support in password_hash()"
    },
    "autoload": {
        "psr-4": {
            "ArgonGuard\\Passwords\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArgonGuard\\Passwords\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
